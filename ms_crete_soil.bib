@article{alhajj-ali2025a-review,
	abstract = {Transforming food systems to ensure adequate and nutritious food while minimising negative environmental and societal impacts requires direct stakeholder involvement in developing nature-based solutions (NbS) for sustainable rural development. The Living Labs (LLs) approach, characterised by open innovation and user-centred design, is gaining attraction as a collaborative space where users co-create, test, and evaluate innovations in real-world settings. While LLs are well established in various fields, their application in agriculture, particularly in forestry and agroforestry, is relatively new. This review highlights, for the first time, the implementation of LLs across agriculture, forestry, and agroforestry sectors. It addresses key concepts of LLs and examines their implementation, benefits, and challenges. Notably, we illustrate and discuss findings from case studies such as REFOREST and SALAM-MED LLs, with the objectives to 1) demonstrate how, in some study cases, LLs can foster stakeholder engagement and co-create knowledge to develop innovative solutions for ecosystem restoration and economic resilience; 2) evaluate the effectiveness of LLs in promoting sustainable practices and propose guidelines for their better implementation; and 3) carry out a comparative analysis to highlight the differences in terms of methodologies, stakeholder involvement, and outcomes between European and North American LL models. While the comparative analysis indicates the need for further investigation, particularly in the economic evaluation of these approaches, this review underscores, in general, the necessity for continued research to optimise the role of LLs in promoting sustainable innovation and collaboration among diverse stakeholders. It aims to enhance understanding of how LLs can improve sustainability in land-use practices while guiding future research and policy development.},
	author = {Alhajj Ali, Salem and Tallou, Anas and Lopriore, Giuseppe and Vivaldi, Gaetano Alessandro and Camposeo, Salvatore and Vogiatzakis, Ioannis Nikolaou and Sanesi, Giovanni},
	date = {2025/06/03/},
	date-added = {2025-09-02 16:41:42 +0300},
	date-modified = {2025-09-02 16:41:42 +0300},
	doi = {https://doi.org/10.1016/j.ijagro.2025.100033},
	isbn = {1125-4718},
	journal = {Italian Journal of Agronomy},
	keywords = {Stakeholder engagement; Open innovation; Participatory approach; Knowledge transfer; Sustainable development; Knowledge co-creation},
	number = {2},
	pages = {100033},
	title = {A review on the role of living labs in advancing sustainable practices in rural areas: Insights from agriculture, forestry, and agroforestry systems},
	url = {https://www.sciencedirect.com/science/article/pii/S1125471825000076},
	volume = {20},
	year = {2025},
	bdsk-url-1 = {https://www.sciencedirect.com/science/article/pii/S1125471825000076},
	bdsk-url-2 = {https://doi.org/10.1016/j.ijagro.2025.100033}}

@article{bennett2022social,
	abstract = {Biodiversity is in precipitous decline globally across both terrestrial and marine environments. Therefore, conservation actions are needed everywhere on Earth, including in the biodiversity rich landscapes and seascapes where people live and work that cover much of the planet. Integrative landscape and seascape approaches to conservation fill this niche. Making evidence-informed conservation decisions within these populated and working landscapes and seascapes requires an in-depth and nuanced understanding of the human dimensions through application of the conservation social sciences. Yet, there has been no comprehensive exploration of potential conservation social science contributions to working landscape and seascape initiatives. We use the Smithsonian Working Land and Seascapes initiative -- an established program with a network of 14 sites around the world -- as a case study to examine what human dimensions topics are key to improving our understanding and how this knowledge can inform conservation in working landscapes and seascapes. This exploratory study identifies 38 topics and linked questions related to how insights from place-based and problem-focused social science might inform the planning, doing, and learning phases of conservation decision-making and adaptive management. Results also show how conservation social science might yield synthetic and theoretical insights that are more broadly applicable. We contend that incorporating insights regarding the human dimensions into integrated conservation initiatives across working landscapes and seascapes will produce more effective, equitable, appropriate and robust conservation actions. Thus, we encourage governments and organizations working on conservation initiatives in working landscapes and seascapes to increase engagement with and funding of conservation social science.},
	author = {Bennett, Nathan J. and Dodge, Molly and Akre, Thomas S. and Canty, Steven W. J. and Chiaravalloti, Rafael and Dayer, Ashley A. and Deichmann, Jessica L. and Gill, David and McField, Melanie and McNamara, James and Murphy, Shannon E. and Nowakowski, A. Justin and Songer, Melissa},
	date-added = {2025-09-02 11:54:59 +0300},
	date-modified = {2025-09-02 11:55:01 +0300},
	doi = {10.3389/fcosc.2022.954930},
	issn = {2673-611X},
	journal = {Frontiers in Conservation Science},
	title = {Social science for conservation in working landscapes and seascapes},
	url = {https://www.frontiersin.org/journals/conservation-science/articles/10.3389/fcosc.2022.954930},
	volume = {Volume 3 - 2022},
	year = {2022},
	bdsk-url-1 = {https://www.frontiersin.org/journals/conservation-science/articles/10.3389/fcosc.2022.954930},
	bdsk-url-2 = {https://doi.org/10.3389/fcosc.2022.954930}}

