	issn = {2073-4441},
	journaltitle = {Water},
	number = {21},
	title = {The LTER-Greece Environmental Observatory Network: Design and Initial Achievements},
	url = {https://www.mdpi.com/2073-4441/13/21/2971},
	volume = {13},
