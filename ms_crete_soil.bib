@article{POULAKAKIS2002,
	abstract = {Despite the fact that during the last century more than 30 studies have been published referring to the fossil elephants of the island of Crete (Greece), there are still many questions that remain unanswered. These questions concern their geographic and phylogenetic origin, how and when they reached the island, the number of valid species, how, when and why each species became extinct and, finally, the possible effect of the phenomenon of dwarfism on each species. (Dwarfism is characteristic of large mammals in insular faunas.) In addition to the available data, which we have reviewed, cross-checked and updated, we describe new fossil elephant material found in the interior of the island, at an altitude of 1000 m above sea level. Using this revised data set, we propose to (1) retain the separate taxonomic status of the dwarf elephant Mammuthus creticus; and (2) join all the described specimens of larger size under the new subspecies name Elephas antiquus creutzburgi. Moreover, in the light of the new approaches that have been attempted for the fossil elephants in other localities of the Mediterranean region, we try to solve and at least explore the mentioned problems and identify the remaining gaps in our knowledge which need to be filled in order to obtain a complete picture of the natural history of the elephants on Crete.},
	author = {Poulakakis, Nikos and Mylonas, Moysis and Lymberakis, Petros and Fassoulas, Charalampos},
	date = {2002},
	doi = {https://doi.org/10.1016/S0031-0182(02)00451-0},
	issn = {0031-0182},
	journaltitle = {Palaeogeography, Palaeoclimatology, Palaeoecology},
	keywords = {Pleistocene,Elephantidae,Crete,Katharo basin,insular fauna},
	number = {1},
	pages = {163--183},
	title = {Origin and taxonomy of the fossil elephants of the island of Crete (Greece): problems and perspectives},
	url = {https://www.sciencedirect.com/science/article/pii/S0031018202004510},
	volume = {186},
	bdsk-url-1 = {https://www.sciencedirect.com/science/article/pii/S0031018202004510},
	bdsk-url-2 = {https://doi.org/10.1016/S0031-0182(02)00451-0}}

@article{Putten2023,
	abstract = {Soil health laws should account for global soil connections Soil biodiversity is crucial for healthy soils, on which we all depend for food, human health, aboveground biodiversity, and climate control. It is well known that land use intensification, climate change, environmental pollution, and mining activities degrade soil biodiversity. However, most current and intended policies on soil protection not only lack a holistic view on how biological, physical, and chemical components of soil health are integrated but also overlook how soils across national borders and continents are connected by human activities. The challenge is to use recent advancements in understanding the distribution and functional roles of soil biodiversity in developing policy on restoring and protecting soil health across borders. Thus, policy should focus not only on soils within a nation or union of nations but also on preventing negative footprints on each other's soils.},
	author = {van der Putten, Wim H. and Bardgett, Richard D. and Farfan, Monica and Montanarella, Luca and Six, Johan and Wall, Diana H.},
	date = {2023},
	doi = {10.1126/science.abn7248},
	eprint = {https://www.science.org/doi/pdf/10.1126/science.abn7248},
	journaltitle = {Science},
	number = {6627},
	pages = {32--34},
	title = {Soil biodiversity needs policy without borders},
	url = {https://www.science.org/doi/abs/10.1126/science.abn7248},
	volume = {379},
