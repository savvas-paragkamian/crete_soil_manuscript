@article{Louca2016,
	abstract = {Microbial metabolism powers biogeochemical cycling in Earth's ecosystems. The taxonomic composition of microbial communities varies substantially between environments, but the ecological causes of this variation remain largely unknown. We analyzed taxonomic and functional community profiles to determine the factors that shape marine bacterial and archaeal communities across the global ocean. By classifying \&gt;30,000 marine microorganisms into metabolic functional groups, we were able to disentangle functional from taxonomic community variation. We find that environmental conditions strongly influence the distribution of functional groups in marine microbial communities by shaping metabolic niches, but only weakly influence taxonomic composition within individual functional groups. Hence, functional structure and composition within functional groups constitute complementary and roughly independent ``axes of variation'' shaped by markedly different processes.},
	author = {Louca, Stilianos and Parfrey, Laura Wegener and Doebeli, Michael},
	date = {2016},
	doi = {10.1126/science.aaf4507},
	eprint = {https://www.science.org/doi/pdf/10.1126/science.aaf4507},
	journaltitle = {Science},
	number = {6305},
	pages = {1272--1277},
	title = {Decoupling function and taxonomy in the global ocean microbiome},
	url = {https://www.science.org/doi/abs/10.1126/science.aaf4507},
	volume = {353},
	bdsk-url-1 = {https://www.science.org/doi/abs/10.1126/science.aaf4507},
